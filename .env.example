# App
NEXT_PUBLIC_SITE_URL=https://vexor.team

# Telegram Bot (for contact form notifications)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=hello@vexor.team

# Analytics (Vercel Analytics — no key needed, enabled via vercel.json)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=auto

# Bundle analyzer (set to 'true' to enable)
ANALYZE=false
